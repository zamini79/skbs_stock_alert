# 이 파일을 복사해 .env 로 만들거나, 아래 줄들을 ~/.zshrc 에 export 하세요.
# 예:  export KIS_APP_KEY="실제키"

# 한국투자증권 KIS Developers — https://apiportal.koreainvestment.com
KIS_APP_KEY=
KIS_APP_SECRET=

# OpenDART — https://opendart.fss.or.kr
DART_API_KEY=
DART_CORP_CODE=          # SK바이오사이언스 8자리 고유번호 (종목코드 아님). corpCode.xml로 조회.

# 네이버 검색 API — https://developers.naver.com
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 텔레그램 — @BotFather 로 봇 생성 후 토큰, 대상 방 chat_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=   # (선택) 보고 누락 등 핵심 실패 통지용 방. 비우면 위 보고 방으로 알림.

# 원인 분석 LLM (둘 중 하나만 있어도 동작 / 둘 다 없으면 원자료 기본 보고서)
#   우선순위: ANTHROPIC > GEMINI. 모두 무료 발급 가능하나 Anthropic은 크레딧 필요.
# Anthropic API — https://console.anthropic.com (크레딧 필요)
ANTHROPIC_API_KEY=
# Google Gemini — https://aistudio.google.com (무료, 카드 불필요)
GEMINI_API_KEY=
GEMINI_MODEL=             # (선택) 기본값 gemini-2.5-flash-lite (무료 티어 호출 가능 모델)

# (선택) 로그 파일 경로. 기본값: ~/.stock_alert_302440.log
LOG_FILE=
